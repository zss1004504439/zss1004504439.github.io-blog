{
  "name": "Letters",
  "version": "1.0.0",
  "description": "极简 Newsletter 风格博客主题，专注阅读体验",
  "author": "Gridea Pro",
  "license": "MIT",
  "engine": "jinja2",
  "minGrideaVersion": "1.0.0",
  "preview": "screenshot.png",

  "config": [
    {
      "group": "基础设置",
      "items": [
        {
          "name": "subtitle",
          "label": "副标题",
          "type": "text",
          "default": "写给自己和世界的信"
        },
        {
          "name": "bio",
          "label": "个人简介",
          "type": "textarea",
          "default": "在这里写下你的个人简介，它会显示在首页头部和关于页面。"
        },
        {
          "name": "avatar",
          "label": "头像",
          "type": "image",
          "default": ""
        }
      ]
    },
    {
      "group": "外观设置",
      "items": [
        {
          "name": "primaryColor",
          "label": "主色调",
          "type": "color",
          "default": "#222222"
        },
        {
          "name": "accentColor",
          "label": "强调色",
          "type": "color",
          "default": "#D97706"
        },
        {
          "name": "fontFamily",
          "label": "正文字体",
          "type": "select",
          "default": "system",
          "options": [
            { "label": "系统默认", "value": "system" },
            { "label": "衬线体", "value": "serif" },
            { "label": "无衬线体", "value": "sans-serif" },
            { "label": "Georgia", "value": "Georgia" },
            { "label": "思源宋体", "value": "Noto Serif SC" }
          ]
        },
        {
          "name": "maxWidth",
          "label": "内容区域宽度",
          "type": "select",
          "default": "720px",
          "options": [
            { "label": "窄 (640px)", "value": "640px" },
            { "label": "标准 (720px)", "value": "720px" },
            { "label": "宽 (800px)", "value": "800px" }
          ]
        },
        {
          "name": "showHeroImage",
          "label": "首页显示头图",
          "type": "boolean",
          "default": false
        },
        {
          "name": "heroImage",
          "label": "首页头图",
          "type": "image",
          "default": ""
        }
      ]
    },
    {
      "group": "功能开关",
      "items": [
        {
          "name": "postsPerPage",
          "label": "每页文章数",
          "type": "number",
          "default": 10,
          "min": 5,
          "max": 30
        },
        {
          "name": "showSearch",
          "label": "显示搜索功能",
          "type": "boolean",
          "default": true
        },
        {
          "name": "showToc",
          "label": "文章页显示目录",
          "type": "boolean",
          "default": true
        },
        {
          "name": "showReadingTime",
          "label": "显示阅读时长",
          "type": "boolean",
          "default": true
        },
        {
          "name": "showTags",
          "label": "文章页显示标签",
          "type": "boolean",
          "default": true
        },
        {
          "name": "showNextPrev",
          "label": "文章页显示上下篇",
          "type": "boolean",
          "default": true
        },
        {
          "name": "showMemos",
          "label": "导航栏显示闪念入口",
          "type": "boolean",
          "default": true
        },
        {
          "name": "showLinks",
          "label": "导航栏显示友链入口",
          "type": "boolean",
          "default": true
        }
      ]
    },
    {
      "group": "社交链接",
      "items": [
        {
          "name": "socialGithub",
          "label": "GitHub",
          "type": "text",
          "default": ""
        },
        {
          "name": "socialTwitter",
          "label": "Twitter / X",
          "type": "text",
          "default": ""
        },
        {
          "name": "socialEmail",
          "label": "邮箱",
          "type": "text",
          "default": ""
        },
        {
          "name": "socialRSS",
          "label": "显示 RSS 订阅",
          "type": "boolean",
          "default": true
        }
      ]
    },
    {
      "group": "自定义代码",
      "items": [
        {
          "name": "customCSS",
          "label": "自定义 CSS",
          "type": "code",
          "language": "css",
          "default": ""
        },
        {
          "name": "customHeader",
          "label": "自定义 Header 代码",
          "type": "code",
          "language": "html",
          "default": ""
        },
        {
          "name": "customFooter",
          "label": "自定义 Footer 代码",
          "type": "code",
          "language": "html",
          "default": ""
        }
      ]
    }
  ]
}
