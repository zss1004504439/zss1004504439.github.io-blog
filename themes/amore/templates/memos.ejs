<%- include('./includes/head', { siteTitle: '闪念 | ' + themeConfig.siteName }) %>

    <body>

        <%- include('./includes/header') %>

            <article class="mod-post mod-post__type-post">

                <header>
                    <h1 class="mod-post__title">闪念</h1>
                </header>

                <div class="mod-post__entry wzulli">

                    <% if (memos && memos.length> 0) { %>

                        <!-- 热力图 -->
                        <style>
                            .heatmap-wrap {
                                margin-bottom: 32px;
                                overflow-x: auto;
                            }

                            .heatmap-wrap table {
                                border-collapse: separate;
                                border-spacing: 3px;
                                width: 100%;
                                table-layout: fixed;
                            }

                            .heatmap-wrap td.cell {
                                border-radius: 2px;
                                height: 13px;
                                cursor: default;
                            }

                            .heatmap-wrap td.cell:hover {
                                outline: 1px solid rgba(40, 223, 153, 0.6);
                                outline-offset: -1px;
                            }

                            .heatmap-wrap td:empty {
                                height: 13px;
                            }

                            .heatmap-month-label {
                                font-size: 11px;
                                color: #999;
                                text-align: left;
                                padding: 0 0 4px 0;
                                line-height: 1;
                            }

                            .heatmap-day-label {
                                font-size: 10px;
                                color: #999;
                                width: 28px;
                                min-width: 28px;
                                max-width: 28px;
                                text-align: right;
                                padding-right: 6px;
                                line-height: 1;
                            }

                            .dark-theme .heatmap-month-label,
                            .dark-theme .heatmap-day-label {
                                color: #666;
                            }

                            .dark-theme .heatmap-wrap td.cell[data-level="0"] {
                                background: #161b22 !important;
                            }

                            .dark-theme .heatmap-wrap td.cell[data-level="1"] {
                                background: #0e4429 !important;
                            }

                            .dark-theme .heatmap-wrap td.cell[data-level="2"] {
                                background: #006d32 !important;
                            }

                            .dark-theme .heatmap-wrap td.cell[data-level="3"] {
                                background: #28df99 !important;
                            }

                            .dark-theme .heatmap-wrap td.cell[data-level="4"] {
                                background: #39d353 !important;
                            }

                            .heatmap-footer {
                                display: flex;
                                justify-content: space-between;
                                align-items: center;
                                margin-top: 6px;
                                font-size: 11px;
                                color: #999;
                            }

                            .heatmap-legend {
                                display: flex;
                                align-items: center;
                                gap: 4px;
                            }

                            .heatmap-legend-cell {
                                width: 10px;
                                height: 10px;
                                border-radius: 2px;
                                display: inline-block;
                            }
                        </style>

                        <div class="heatmap-wrap">
                            <div id="heatmap-root"></div>
                            <div class="heatmap-footer">
                                <span id="heatmap-total"></span>
                                <div class="heatmap-legend">
                                    <span>少</span>
                                    <span class="heatmap-legend-cell" style="background:#ebedf0;"></span>
                                    <span class="heatmap-legend-cell" style="background:#9be9a8;"></span>
                                    <span class="heatmap-legend-cell" style="background:#40c463;"></span>
                                    <span class="heatmap-legend-cell" style="background:#28df99;"></span>
                                    <span class="heatmap-legend-cell" style="background:#1a9f6b;"></span>
                                    <span>多</span>
                                </div>
                            </div>
                        </div>

                        <!-- 闪念列表 -->
                        <div class="memos-list">
                            <% memos.forEach(function(memo, index) { %>
                                <div class="memo-item <%= index >= 20 ? 'memo-hide' : '' %>"
                                    data-created="<%= memo.createdAt %>"
                                    style="position: relative; margin-bottom: 20px; padding: 20px 24px; border-left: 3px solid #28df99; background: linear-gradient(135deg, rgba(40,223,153,0.03) 0%, rgba(255,255,255,0.8) 100%); border-radius: 0 10px 10px 0; transition: all 0.2s ease;">
                                    <div class="memo-body"
                                        style="max-height: 160px; overflow: hidden; position: relative; transition: max-height 0.3s ease;">
                                        <div class="memo-content"
                                            style="font-size: 14px; line-height: 1.9; color: #333; word-wrap: break-word;">
                                            <%- memo.content %>
                                        </div>
                                    </div>
                                    <% if (memo.tags && memo.tags.length> 0) { %>
                                        <div class="memo-tags"
                                            style="margin-top: 10px; display: flex; flex-wrap: wrap; gap: 6px;">
                                            <% memo.tags.forEach(function(tag) { %>
                                                <span
                                                    style="display: inline-block; padding: 1px 10px; font-size: 11px; color: #28df99; background: rgba(40,223,153,0.08); border-radius: 20px; border: 1px solid rgba(40,223,153,0.2);">#
                                                    <%= tag %>
                                                </span>
                                                <% }); %>
                                        </div>
                                        <% } %>
                                            <div class="memo-meta"
                                                style="margin-top: 10px; font-size: 12px; color: #aaa; display: flex; justify-content: space-between; align-items: center;">
                                                <time>
                                                    <%= memo.dateFormat %>
                                                </time>
                                            </div>
                                </div>
                                <% }); %>
                        </div>

                        <!-- 分页控件 -->
                        <style>
                            .memo-hide {
                                display: none;
                            }

                            .memo-item:hover {
                                background: linear-gradient(135deg, rgba(40, 223, 153, 0.06) 0%, rgba(255, 255, 255, 0.9) 100%) !important;
                            }

                            .memo-expand-btn {
                                display: none;
                                margin-top: 4px;
                                font-size: 12px;
                                color: #28df99;
                                cursor: pointer;
                                border: none;
                                background: none;
                                padding: 0;
                            }

                            .memo-expand-btn:hover {
                                text-decoration: underline;
                            }

                            .memo-body.collapsed::after {
                                content: '';
                                position: absolute;
                                bottom: 0;
                                left: 0;
                                right: 0;
                                height: 40px;
                                background: linear-gradient(transparent, rgba(255, 255, 255, 0.95));
                                pointer-events: none;
                            }

                            .dark-theme .memo-item {
                                background: linear-gradient(135deg, rgba(40, 223, 153, 0.06) 0%, rgba(41, 42, 45, 0.8) 100%) !important;
                            }

                            .dark-theme .memo-item:hover {
                                background: linear-gradient(135deg, rgba(40, 223, 153, 0.1) 0%, rgba(41, 42, 45, 0.9) 100%) !important;
                            }

                            .dark-theme .memo-content {
                                color: #a9a9b3 !important;
                            }

                            .dark-theme .memo-meta {
                                color: #666 !important;
                            }

                            .dark-theme .memo-body.collapsed::after {
                                background: linear-gradient(transparent, rgba(41, 42, 45, 0.95));
                            }

                            .memo-pagination {
                                display: flex;
                                justify-content: center;
                                gap: 12px;
                                margin-top: 24px;
                            }

                            .memo-pagination a {
                                padding: 6px 16px;
                                font-size: 13px;
                                color: #28df99;
                                border: 1px solid rgba(40, 223, 153, 0.3);
                                border-radius: 20px;
                                cursor: pointer;
                                transition: all 0.2s;
                                text-decoration: none;
                            }

                            .memo-pagination a:hover {
                                background: rgba(40, 223, 153, 0.1);
                                color: #1a9f6b;
                            }

                            .memo-pagination .disabled {
                                opacity: 0.3;
                                pointer-events: none;
                            }

                            .memo-page-info {
                                font-size: 12px;
                                color: #999;
                                display: flex;
                                align-items: center;
                            }
                        </style>

                        <div class="memo-pagination" id="memo-pagination">
                            <a href="javascript:void(0);" id="memo-prev-btn" class="disabled" onclick="memoPrevPage()">←
                                上一页</a>
                            <span class="memo-page-info" id="memo-page-info"></span>
                            <a href="javascript:void(0);" id="memo-next-btn" onclick="memoNextPage()">下一页 →</a>
                        </div>

                        <script>
                            (function () {
                                var MEMO_PER_PAGE = 20;
                                var currentPage = 1;
                                var items = document.querySelectorAll('.memo-item');
                                var totalItems = items.length;
                                var totalPages = Math.ceil(totalItems / MEMO_PER_PAGE);

                                // 初始化内容折叠
                                items.forEach(function (item) {
                                    var body = item.querySelector('.memo-body');
                                    var content = item.querySelector('.memo-content');
                                    if (content && content.scrollHeight > 160) {
                                        body.classList.add('collapsed');
                                        var btn = document.createElement('button');
                                        btn.className = 'memo-expand-btn';
                                        btn.style.display = 'inline';
                                        btn.textContent = '展开全文 ▼';
                                        btn.onclick = function () {
                                            if (body.classList.contains('collapsed')) {
                                                body.style.maxHeight = content.scrollHeight + 'px';
                                                body.classList.remove('collapsed');
                                                btn.textContent = '收起 ▲';
                                            } else {
                                                body.style.maxHeight = '160px';
                                                body.classList.add('collapsed');
                                                btn.textContent = '展开全文 ▼';
                                            }
                                        };
                                        body.parentNode.insertBefore(btn, body.nextSibling);
                                    }
                                });

                                // ======= GitHub 风格热力图 =======
                                var heatmapData = {};
                                items.forEach(function (item) {
                                    var d = item.getAttribute('data-created');
                                    if (d) {
                                        var dateStr = d.substring(0, 10);
                                        heatmapData[dateStr] = (heatmapData[dateStr] || 0) + 1;
                                    }
                                });

                                var COLORS = ['#ebedf0', '#9be9a8', '#40c463', '#28df99', '#1a9f6b'];
                                var MONTHS = ['1月', '2月', '3月', '4月', '5月', '6月', '7月', '8月', '9月', '10月', '11月', '12月'];
                                var DAYS = ['日', '一', '二', '三', '四', '五', '六'];

                                var today = new Date();
                                today.setHours(0, 0, 0, 0);
                                // 找到 ~53 周前的周日作为起点（约一年）
                                var endDay = today.getDay(); // 0=Sun
                                var totalDays = 52 * 7 + endDay + 1;
                                var startDate = new Date(today);
                                startDate.setDate(startDate.getDate() - totalDays + 1);
                                // 对齐到周日
                                startDate.setDate(startDate.getDate() - startDate.getDay());

                                var totalWeeks = Math.ceil(totalDays / 7);

                                // 构建周列数据
                                var weeks = [];
                                for (var w = 0; w < totalWeeks; w++) {
                                    var week = [];
                                    for (var d = 0; d < 7; d++) {
                                        var cellDate = new Date(startDate);
                                        cellDate.setDate(cellDate.getDate() + w * 7 + d);
                                        var key = cellDate.getFullYear() + '-' + String(cellDate.getMonth() + 1).padStart(2, '0') + '-' + String(cellDate.getDate()).padStart(2, '0');
                                        var count = heatmapData[key] || 0;
                                        var level = count === 0 ? 0 : count === 1 ? 1 : count <= 3 ? 2 : count <= 5 ? 3 : 4;
                                        var future = cellDate > today;
                                        week.push({ date: cellDate, key: key, count: count, level: level, future: future, month: cellDate.getMonth(), dayOfMonth: cellDate.getDate() });
                                    }
                                    weeks.push(week);
                                }

                                // 计算月份标签：在月份的第一个出现的那一周标出
                                var monthLabels = []; // { weekIndex, label }
                                var lastMonth = -1;
                                for (var w = 0; w < weeks.length; w++) {
                                    // 使用该周的第一天（周日）的月份
                                    var firstDay = weeks[w][0];
                                    if (!firstDay.future && firstDay.month !== lastMonth) {
                                        monthLabels.push({ weekIndex: w, label: MONTHS[firstDay.month] });
                                        lastMonth = firstDay.month;
                                    }
                                }

                                // 构建 HTML 表格
                                // 添加 min-width 确保不被压缩，允许横向滚动
                                var html = '<table style="min-width: 600px;">';

                                // 月份行
                                html += '<tr><td class="heatmap-day-label"></td>';
                                var monthColIdx = 0;
                                for (var w = 0; w < totalWeeks; w++) {
                                    if (monthColIdx < monthLabels.length && monthLabels[monthColIdx].weekIndex === w) {
                                        // 计算 colspan: 直到下一个月标签或结尾
                                        var nextIdx = monthColIdx + 1 < monthLabels.length ? monthLabels[monthColIdx + 1].weekIndex : totalWeeks;
                                        var span = nextIdx - w;
                                        html += '<td colspan="' + span + '" class="heatmap-month-label">' + monthLabels[monthColIdx].label + '</td>';
                                        w += span - 1; // 跳过已合并的列
                                        monthColIdx++;
                                    } else {
                                        html += '<td class="heatmap-month-label"></td>';
                                    }
                                }
                                html += '</tr>';

                                // 7 行（周日到周六）
                                for (var d = 0; d < 7; d++) {
                                    html += '<tr>';
                                    html += '<td class="heatmap-day-label">' + DAYS[d] + '</td>';
                                    for (var w = 0; w < weeks.length; w++) {
                                        var c = weeks[w][d];
                                        if (c.future) {
                                            html += '<td></td>';
                                        } else {
                                            html += '<td class="cell" data-level="' + c.level + '" style="background:' + COLORS[c.level] + ';" title="' + c.key + ': ' + c.count + ' 条闪念"></td>';
                                        }
                                    }
                                    html += '</tr>';
                                }

                                html += '</table>';
                                var root = document.getElementById('heatmap-root');
                                root.innerHTML = html;
                                document.getElementById('heatmap-total').textContent = '过去一年共 ' + totalItems + ' 条闪念';

                                // 自动滚动到最右侧
                                setTimeout(function () {
                                    var wrap = document.querySelector('.heatmap-wrap');
                                    if (wrap) {
                                        wrap.scrollLeft = wrap.scrollWidth;
                                    }
                                }, 100);

                                // ======= 分页 =======
                                function updatePagination() {
                                    for (var i = 0; i < items.length; i++) {
                                        var start = (currentPage - 1) * MEMO_PER_PAGE;
                                        var end = currentPage * MEMO_PER_PAGE;
                                        if (i >= start && i < end) {
                                            items[i].classList.remove('memo-hide');
                                        } else {
                                            items[i].classList.add('memo-hide');
                                        }
                                    }
                                    var prevBtn = document.getElementById('memo-prev-btn');
                                    var nextBtn = document.getElementById('memo-next-btn');
                                    var pageInfo = document.getElementById('memo-page-info');

                                    prevBtn.className = currentPage <= 1 ? 'disabled' : '';
                                    nextBtn.className = currentPage >= totalPages ? 'disabled' : '';
                                    pageInfo.textContent = currentPage + ' / ' + totalPages;

                                    if (totalPages <= 1) {
                                        document.getElementById('memo-pagination').style.display = 'none';
                                    }
                                }

                                window.memoNextPage = function () {
                                    if (currentPage < totalPages) { currentPage++; updatePagination(); window.scrollTo(0, 0); }
                                };
                                window.memoPrevPage = function () {
                                    if (currentPage > 1) { currentPage--; updatePagination(); window.scrollTo(0, 0); }
                                };

                                updatePagination();
                            })();
                        </script>

                        <% } else { %>
                            <p style="text-align: center; color: #999; padding: 40px 0;">暂无闪念</p>
                            <% } %>

                </div>

                <%- include('./includes/comments') %>

            </article>

            <%- include('./includes/footer') %>

    </body>

    </html>