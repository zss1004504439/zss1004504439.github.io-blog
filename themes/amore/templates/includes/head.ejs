<!DOCTYPE HTML>
<html lang="zh-CN">

<head>
    <meta charset="utf-8" />
    <meta name="viewport"
        content="initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0, user-scalable=0, width=device-width" />
    <meta name="renderer" content="webkit">
    <meta name="format-detection" content="telephone=no, email=no, address=no">

    <title><%= siteTitle %></title>
    
    <% 
    let keywords = site.customConfig.keywords || ''; 
    if (site.tags && site.tags.length > 0) {
        let sortedTags = site.tags.slice().sort((a, b) => b.count - a.count);
        let topTags = sortedTags.slice(0, 20).map(tag => tag.name).join(',');
        if (keywords && topTags) {
            keywords += ',' + topTags;
        } else if (topTags) {
            keywords = topTags;
        }
    }

    let description = site.customConfig.metaDescription || themeConfig.siteDescription;
    if (typeof post !== 'undefined') {
        if (post.description) {
            description = post.description;
        } else if (post.abstract) {
            description = post.abstract;
        }
    }

    let ogImage = site.customConfig.avatar;
    if (typeof post !== 'undefined' && post.feature) {
        ogImage = post.feature;
    }

    let currentUrl = themeConfig.domain;
    if (typeof post !== 'undefined' && post.link) {
        currentUrl = post.link;
    }
    %>
    <meta name="keywords" content="<%= keywords %>" />
    <meta name="description" content="<%= description %>">

    <!-- Social Media Meta Tags -->
    <meta property="og:type" content="<%= typeof post !== 'undefined' ? 'article' : 'website' %>">
    <meta property="og:url" content="<%= currentUrl %>">
    <meta property="og:title" content="<%= siteTitle %>">
    <meta property="og:description" content="<%= description %>">
    <meta property="og:image" content="<%= ogImage %>">
    <meta property="og:site_name" content="<%= themeConfig.siteName %>">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:url" content="<%= currentUrl %>">
    <meta name="twitter:title" content="<%= siteTitle %>">
    <meta name="twitter:description" content="<%= description %>">
    <meta name="twitter:image" content="<%= ogImage %>">

    <!-- Structured Data (JSON-LD) -->
    <%
    let schema = {
        "@context": "https://schema.org",
        "@type": typeof post !== 'undefined' ? "BlogPosting" : "WebSite",
        "headline": siteTitle,
        "description": description,
        "image": ogImage,
        "author": {
            "@type": "Person",
            "name": themeConfig.siteName
        },
        "publisher": {
            "@type": "Organization",
            "name": themeConfig.siteName,
            "logo": {
                "@type": "ImageObject",
                "url": site.customConfig.avatar
            }
        }
    };
    if (typeof post !== 'undefined') {
        const isoDate = new Date(post.date).toISOString();
        schema.datePublished = isoDate;
        schema.dateModified = isoDate;
        schema.mainEntityOfPage = {
            "@type": "WebPage",
            "@id": currentUrl
        };
    } else {
        schema.url = currentUrl;
    }
    %>
    <script type="application/ld+json">
        <%- JSON.stringify(schema) %>
    </script>
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)">
    <meta name="theme-color" content="#292a2d" media="(prefers-color-scheme: dark)">

    <% 
    let cdnPrefix = themeConfig.domain;
    if (site.customConfig.cdnPrefix) {
        cdnPrefix = site.customConfig.cdnPrefix;
    } else if (site.customConfig.githubUser && site.customConfig.repoName) {
        cdnPrefix = 'https://cdn.jsdelivr.net/gh/' + site.customConfig.githubUser + '/' + site.customConfig.repoName + '@' + (site.customConfig.branch || 'master');
    }
    %>
    <% if (site.customConfig.favicon) { %>
    <link rel="shortcut icon" href="<%= site.customConfig.favicon %>">
    <% } else { %>
    <link rel="shortcut icon" href="<%= cdnPrefix %>/media/images/favicon.ico">
    <% } %>
    <link rel="stylesheet" href="<%= cdnPrefix %>/styles/main.css">
    
    <%- include('./global-seo') %>
    <%- include('./scripts') %>


    <% if (site.customConfig.ga) { %>
    <script async src="https://www.googletagmanager.com/gtag/js?id=<%= site.customConfig.ga %>"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', '<%= site.customConfig.ga %>');
    </script>
    <% } %>
</head>